---
import MainLayout from '../../layouts/MainLayout.astro';
import channelsData from '../../../public/assets/data/channels.json';

export const prerender = true;

// Helper to generate the same slug as in watch/[id].astro
function slugify(text) {
  return text
    .toString()
    .toLowerCase()
    .trim()
    .replace(/\s+/g, '-')
    .replace(/[^\w\-]+/g, '')
    .replace(/\-\-+/g, '-')
    .replace(/^-+/, '')
    .replace(/-+$/, '');
}

function getChannelSlug(channel) {
  const nameSlug = slugify(channel.name);
  const id = channel.id;
  if (id.startsWith(nameSlug) || id.endsWith(nameSlug)) {
    return id;
  }
  return `${nameSlug}-${id}`;
}

const categories = channelsData.categories;
---
<MainLayout title="Live TV Channels Directory | Vibestream" showPlayer={false}>
  <div class="portal-wrapper">
    <div class="portal-header">
      <h1 class="portal-title">Explore Live TV Channels</h1>
      <p class="portal-subtitle">Select any channel from sports, movies, news, and entertainment to start streaming instantly.</p>
      
      <!-- Search Input -->
      <div class="search-container">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input type="text" id="channelSearch" placeholder="Search channels by name..." autocomplete="off" />
      </div>
    </div>

    <!-- Category Sections -->
    <div class="portal-categories">
      {Object.keys(categories).map(catKey => {
        const category = categories[catKey];
        if (!category.channels || category.channels.length === 0) return null;
        return (
          <section class="portal-category-section" data-category={catKey}>
            <div class="category-header">
              <h2 class="category-title">{category.name}</h2>
              <span class="channel-count">{category.channels.length} {category.channels.length === 1 ? 'Channel' : 'Channels'}</span>
            </div>
            <div class="portal-channel-grid">
              {category.channels.map(channel => {
                const slug = getChannelSlug(channel);
                const href = `/watch/${slug}`;
                return (
                  <a href={href} class="portal-channel-card" data-id={channel.id} data-name={channel.name}>
                    <div class="card-logo-container">
                      {channel.logo ? (
                        <img 
                          src={channel.logo} 
                          alt={channel.name} 
                          class="card-logo" 
                          loading="lazy" 
                          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                        />
                        <div class="card-fallback-name" style="display: none;">
                          {channel.name}
                        </div>
                      ) : (
                        <div class="card-fallback-name">
                          {channel.name}
                        </div>
                      )}
                      <div class="card-hover-overlay">
                        <div class="play-button">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <polygon points="5 3 19 12 5 21 5 3"></polygon>
                          </svg>
                        </div>
                      </div>
                    </div>
                    <div class="card-details">
                      <span class="card-name">{channel.name}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>
  </div>
</MainLayout>

<style>
  .portal-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    animation: fadeIn 0.5s ease-out;
  }

  .portal-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .portal-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #a5b4fc 0%, #6366f1 50%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .portal-subtitle {
    font-size: 1rem;
    color: #a1a1aa;
    max-width: 600px;
    margin: 0 auto 2rem auto;
    line-height: 1.5;
  }

  /* Search Bar */
  .search-container {
    position: relative;
    max-width: 500px;
    margin: 0 auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    border-radius: 12px;
  }

  .search-icon {
    position: absolute;
    left: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    color: #71717a;
    pointer-events: none;
    transition: color 0.3s ease;
  }

  #channelSearch {
    width: 100%;
    padding: 1rem 1rem 1rem 3.5rem;
    background: #141414;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    color: #ffffff;
    font-size: 1rem;
    font-family: inherit;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    outline: none;
  }

  #channelSearch:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
    background: #1a1a1a;
  }

  #channelSearch:focus + .search-icon {
    color: #6366f1;
  }

  /* Categories & Grids */
  .portal-categories {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .portal-category-section {
    animation: fadeIn 0.4s ease-out;
  }

  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid #2a2a2a;
    padding-bottom: 0.75rem;
  }

  .category-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
  }

  .channel-count {
    font-size: 0.875rem;
    color: #71717a;
    font-weight: 500;
  }

  .portal-channel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1.5rem;
  }

  /* Cards */
  .portal-channel-card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, #141414 0%, #0d0d0f 100%);
    border: 1px solid #2a2a2a;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .portal-channel-card:hover {
    transform: translateY(-6px);
    border-color: #6366f1;
    box-shadow: 0 10px 25px rgba(99, 102, 241, 0.2), 0 0 0 1px rgba(99, 102, 241, 0.2);
  }

  .card-logo-container {
    aspect-ratio: 16/10;
    width: 100%;
    position: relative;
    background: #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid #1f1f1f;
  }

  .card-logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .portal-channel-card:hover .card-logo {
    transform: scale(1.08);
  }

  .card-fallback-name {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 1rem;
    font-weight: 700;
    color: #a1a1aa;
    padding: 1rem;
    background: linear-gradient(135deg, #1f1f2e 0%, #11111b 100%);
    text-transform: uppercase;
  }

  /* Hover Overlay & Play Icon */
  .card-hover-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 2;
  }

  .portal-channel-card:hover .card-hover-overlay {
    opacity: 1;
  }

  .play-button {
    width: 44px;
    height: 44px;
    background: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000000;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    transform: scale(0.8);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .play-button svg {
    margin-left: 3px;
  }

  .portal-channel-card:hover .play-button {
    transform: scale(1);
    background: #6366f1;
    color: #ffffff;
  }

  /* Card Details */
  .card-details {
    padding: 0.875rem 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #141414;
  }

  .card-name {
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
    transition: color 0.3s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .portal-channel-card:hover .card-name {
    color: #a5b4fc;
  }

  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile responsiveness adjustments for full width layout */
  @media (max-width: 768px) {
    .portal-wrapper {
      padding: 1.5rem 1rem;
    }
    
    .portal-title {
      font-size: 2rem;
    }

    .portal-subtitle {
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    .portal-channel-grid {
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 1rem;
    }

    .play-button {
      width: 36px;
      height: 36px;
    }
  }
</style>

<script>
  // Real-time channel search filter logic
  const searchInput = document.getElementById('channelSearch') as HTMLInputElement;
  const channelCards = document.querySelectorAll('.portal-channel-card') as NodeListOf<HTMLAnchorElement>;
  const categorySections = document.querySelectorAll('.portal-category-section') as NodeListOf<HTMLElement>;

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      
      categorySections.forEach(section => {
        let visibleChannelsInSection = 0;
        const cards = section.querySelectorAll('.portal-channel-card') as NodeListOf<HTMLAnchorElement>;
        
        cards.forEach(card => {
          const name = card.dataset.name ? card.dataset.name.toLowerCase() : '';
          const id = card.dataset.id ? card.dataset.id.toLowerCase() : '';
          
          if (name.includes(query) || id.includes(query)) {
            card.style.display = 'flex';
            visibleChannelsInSection++;
          } else {
            card.style.display = 'none';
          }
        });
        
        // Hide the category section if no channels match the search query
        if (visibleChannelsInSection > 0) {
          section.style.display = 'block';
        } else {
          section.style.display = 'none';
        }
      });
    });
  }
</script>
