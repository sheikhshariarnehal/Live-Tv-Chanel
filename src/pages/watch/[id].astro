---
import MainLayout from '../../layouts/MainLayout.astro';
import channelsData from '../../../public/assets/data/channels.json';

export const prerender = true;

export function slugify(text) {
  return text
    .toString()
    .toLowerCase()
    .trim()
    .replace(/\s+/g, '-')
    .replace(/[^\w\-]+/g, '')
    .replace(/\-\-+/g, '-')
    .replace(/^-+/, '')
    .replace(/-+$/, '');
}

export function getChannelSlug(channel) {
  const nameSlug = slugify(channel.name);
  const id = channel.id;
  if (id.startsWith(nameSlug) || id.endsWith(nameSlug)) {
    return id;
  }
  return `${nameSlug}-${id}`;
}

export function getStaticPaths() {
  const paths = [];
  const categories = channelsData.categories;
  
  for (const catKey in categories) {
    const category = categories[catKey];
    if (category.channels) {
      category.channels.forEach(channel => {
        const slug = getChannelSlug(channel);
        
        // Add path for the custom slug
        paths.push({
          params: { id: slug },
          props: { channel }
        });
        
        // If the raw channel.id is different from the custom slug, add a path for it too
        if (channel.id !== slug) {
          paths.push({
            params: { id: channel.id },
            props: { channel }
          });
        }
      });
    }
  }
  
  return paths;
}

const { channel } = Astro.props;

if (!channel) {
  return Astro.redirect('/');
}

let title = `Watch ${channel.name} Live | Vibestream`;
let description = `Watch ${channel.name} live stream in HD quality. Access sports, movies, news, and entertainment with Vibestream player.`;
let keywords = `Watch ${channel.name} Live, ${channel.name} Live Stream, ${channel.name} Online, watch live tv, iptv player, Vibestream`;

if (channel.id === 'sports-cazetv') {
  title = `CazeTV Live - FIFA World Cup Football | Vibestream`;
  description = `Watch FIFA World Cup live on CazeTV with Vibestream. Enjoy HD sports streaming with no interruptions and no signup required..`;
  keywords = `CazeTV, watch CazeTV live, CazeTV live stream, FIFA World Cup, FIFA World Cup live, sports streaming, Vibestream`;
} else if (channel.id === 'sports-beinsports') {
  title = `BeinSports Live - FIFA World Cup Football | Vibestream`;
  description = `Watch FIFA World Cup live on BeinSports with Vibestream. Enjoy HD sports streaming with no interruptions and no signup required..`;
  keywords = `BeinSports, watch BeinSports live, BeinSports live stream, FIFA World Cup, FIFA World Cup live, sports streaming, Vibestream`;
}

const image = channel.logo || "https://vibestream.app/assets/image/og-image.png";
const activeChannelId = channel.id;

// Generate Schema.org structured data for rich snippet search results
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${Astro.url.href}#webpage`,
      "url": Astro.url.href,
      "name": title,
      "description": description,
      "isPartOf": {
        "@type": "WebSite",
        "@id": `${Astro.url.origin}/#website`,
        "url": `${Astro.url.origin}/`,
        "name": "Vibestream"
      }
    },
    {
      "@type": "BroadcastService",
      "@id": `${Astro.url.href}#broadcastservice`,
      "name": channel.name,
      "broadcastDisplayName": channel.name,
      "videoFormat": "HD",
      "description": description,
      "logo": image,
      "url": Astro.url.href,
      "provider": {
        "@type": "Organization",
        "name": "Vibestream",
        "url": Astro.url.origin
      }
    }
  ]
};
---
<MainLayout title={title} description={description} keywords={keywords} image={image} activeChannelId={activeChannelId} schema={schema} />
