---
const { pathname } = Astro.url;
---

<!-- Mobile Navigation Overlay Drawer -->
<div class="mobile-nav-overlay" id="mobileNavOverlay">
  <div class="mobile-nav-drawer">
    <div class="mobile-nav-header">
      <a href="/" class="logo">
        <img 
          src="/assets/logo.webp" 
          alt="Vibestream Logo" 
          class="logo-img" 
          width="32" 
          height="32" 
          loading="eager" 
          decoding="async" 
        />
        <div class="logo-text-group">
          <span class="logo-text">Vibestream</span>
          <span class="logo-subtitle">Live TV & IPTV</span>
        </div>
      </a>
      <button class="btn-close-nav" id="closeNavBtn" title="Close Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <nav class="mobile-nav-menu">
      <a href="/" class={`mobile-nav-link ${pathname === "/" || pathname.startsWith("/watch") ? "active" : ""}`}>
        <svg class="nav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="15" rx="2.18" ry="2.18"></rect>
          <line x1="7" y1="22" x2="17" y2="22"></line>
          <line x1="12" y1="17" x2="12" y2="22"></line>
        </svg>
        <span>Channels</span>
      </a>
      <a href="/upcoming" class={`mobile-nav-link ${pathname === "/upcoming" ? "active" : ""}`}>
        <svg class="nav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span>Schedule</span>
      </a>
    </nav>
    <div class="mobile-nav-footer">
      <p>© 2026 Vibestream. All rights reserved.</p>
    </div>
  </div>
</div>
